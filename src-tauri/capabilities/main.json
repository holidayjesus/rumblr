{
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:webview:deny-internal-toggle-devtools",
    "core:event:default",
    "core:window:default",
    "core:menu:default",
    "core:image:default",
    "core:resources:default",
    "core:path:default",
    "core:app:default",
    "notification:default",
    "opener:default"
  ]
}
